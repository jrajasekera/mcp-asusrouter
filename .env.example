# ASUS router connection settings for the MCP server.
# Copy this file to `.env` and fill in your values. Do NOT commit `.env`.
# These may also be supplied as real environment variables (same names).

# Required
ROUTER_HOSTNAME=192.168.1.1
ROUTER_PASSWORD=your-router-password

# Optional (defaults shown)
ROUTER_USERNAME=admin
ROUTER_USE_SSL=false
